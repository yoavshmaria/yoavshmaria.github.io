<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>HSBC UK Marketing Intelligence</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<style>
  :root {
    --hsbc-red: #DB0011;
    --hsbc-dark: #1a1a1a;
    --hsbc-light: #f5f5f5;
    --hsbc-mid: #333;
    --hsbc-accent: #b0000c;
    --card-bg: #ffffff;
    --border: #e8e8e8;
    --text: #1a1a1a;
    --muted: #666;
    --pill-bg: #fff0f0;
    --success: #1a7a3c;
    --warning: #c07a00;
    --danger: #DB0011;
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --card-bg: #1e1e1e;
      --border: #333;
      --text: #f0f0f0;
      --muted: #aaa;
      --hsbc-light: #111;
      --pill-bg: #2a1010;
    }
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--hsbc-light); color: var(--text); font-size: 14px; }

  /* NAV */
  .header { background: var(--hsbc-dark); padding: 0 24px; display: flex; align-items: center; gap: 0; position: sticky; top: 0; z-index: 100; box-shadow: 0 2px 8px rgba(0,0,0,.3); }
  .logo-area { display: flex; align-items: center; gap: 12px; padding: 14px 0; margin-right: 32px; border-right: 1px solid #333; padding-right: 32px; }
  .logo-hex { width: 36px; height: 36px; background: var(--hsbc-red); display: flex; align-items: center; justify-content: center; }
  .logo-hex svg { width: 22px; height: 22px; }
  .logo-text { color: #fff; font-size: 16px; font-weight: 600; letter-spacing: .5px; }
  .logo-sub { color: #aaa; font-size: 11px; letter-spacing: 1px; text-transform: uppercase; margin-top: 1px; }
  nav { display: flex; gap: 2px; overflow-x: auto; padding: 0 0 0 4px; }
  nav button { background: none; border: none; color: #ccc; padding: 18px 14px; font-size: 12px; font-weight: 500; cursor: pointer; white-space: nowrap; border-bottom: 2px solid transparent; transition: all .2s; letter-spacing: .3px; }
  nav button:hover { color: #fff; }
  nav button.active { color: #fff; border-bottom-color: var(--hsbc-red); }
  .data-badge { background: var(--hsbc-red); color: #fff; font-size: 9px; padding: 2px 5px; border-radius: 3px; margin-left: 5px; }

  /* PAGES */
  .page { display: none; padding: 24px; max-width: 1200px; margin: 0 auto; }
  .page.active { display: block; }

  /* CARDS */
  .card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 8px; padding: 20px; margin-bottom: 16px; }
  .card-title { font-size: 13px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: .8px; margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }
  .card-title .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--hsbc-red); }

  /* KPI GRID */
  .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px; margin-bottom: 16px; }
  .kpi { background: var(--card-bg); border: 1px solid var(--border); border-radius: 8px; padding: 16px; }
  .kpi-label { font-size: 11px; color: var(--muted); font-weight: 500; text-transform: uppercase; letter-spacing: .6px; margin-bottom: 6px; }
  .kpi-value { font-size: 24px; font-weight: 700; color: var(--text); line-height: 1; }
  .kpi-sub { font-size: 11px; margin-top: 5px; }
  .up { color: var(--success); } .down { color: var(--danger); }

  /* CHARTS */
  .chart-wrap { position: relative; width: 100%; }
  .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .grid3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
  @media(max-width:700px) { .grid2, .grid3 { grid-template-columns: 1fr; } }

  /* TABLES */
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th { color: var(--muted); font-weight: 600; text-align: left; padding: 8px 12px; border-bottom: 1px solid var(--border); font-size: 11px; text-transform: uppercase; letter-spacing: .5px; }
  td { padding: 10px 12px; border-bottom: 1px solid var(--border); }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: rgba(219,0,17,.03); }
  .tag { display: inline-block; padding: 2px 8px; border-radius: 4px; font-size: 11px; font-weight: 500; }
  .tag-red { background: #fff0f0; color: var(--hsbc-red); }
  .tag-green { background: #f0fff4; color: var(--success); }
  .tag-orange { background: #fff8e6; color: var(--warning); }
  .tag-blue { background: #e8f4ff; color: #1565c0; }
  .tag-gray { background: #f5f5f5; color: #555; }
  .bar { height: 6px; border-radius: 3px; background: var(--border); overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 3px; background: var(--hsbc-red); }

  /* OVERVIEW */
  .opportunity-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 14px; margin-bottom: 16px; }
  .opp-card { background: var(--card-bg); border: 1px solid var(--border); border-radius: 8px; padding: 16px; border-left: 3px solid var(--hsbc-red); }
  .opp-icon { font-size: 20px; margin-bottom: 8px; }
  .opp-title { font-size: 13px; font-weight: 700; margin-bottom: 4px; }
  .opp-desc { font-size: 12px; color: var(--muted); line-height: 1.5; }
  .action-item { display: flex; align-items: flex-start; gap: 10px; padding: 10px 0; border-bottom: 1px solid var(--border); }
  .action-item:last-child { border-bottom: none; }
  .action-num { min-width: 22px; height: 22px; background: var(--hsbc-red); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; }
  .action-text { font-size: 13px; line-height: 1.5; }
  .priority { font-size: 10px; padding: 1px 6px; border-radius: 3px; font-weight: 600; display: inline-block; margin-left: 6px; }
  .p-high { background: #fff0f0; color: var(--hsbc-red); }
  .p-med { background: #fff8e6; color: var(--warning); }

  /* SWOT */
  .swot-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; border-radius: 8px; overflow: hidden; }
  .swot-q { padding: 20px; }
  .swot-q h3 { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; opacity: .85; }
  .swot-q ul { list-style: none; padding: 0; }
  .swot-q ul li { font-size: 12px; line-height: 1.6; padding: 4px 0 4px 14px; position: relative; }
  .swot-q ul li::before { content: '▸'; position: absolute; left: 0; opacity: .7; }
  .sq-s { background: #1a4d28; color: #c8ffd4; }
  .sq-w { background: #4d1a1a; color: #ffd4d4; }
  .sq-o { background: #1a3a4d; color: #d4efff; }
  .sq-t { background: #3d3000; color: #ffe8a0; }
  .swot-label { text-align: center; font-size: 11px; color: var(--muted); margin-bottom: 6px; font-weight: 600; letter-spacing: 1px; text-transform: uppercase; }

  /* COMPETITOR */
  .comp-row { display: flex; align-items: center; gap: 10px; padding: 8px 0; border-bottom: 1px solid var(--border); }
  .comp-row:last-child { border-bottom: none; }
  .comp-name { font-weight: 600; font-size: 13px; min-width: 130px; }
  .comp-bar { flex: 1; }
  .comp-val { font-size: 12px; color: var(--muted); min-width: 70px; text-align: right; }

  /* SOCIAL */
  .social-icon { width: 28px; height: 28px; border-radius: 6px; display: inline-flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; color: #fff; margin-right: 8px; }

  /* REFERRAL */
  .ref-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  @media(max-width:700px) { .ref-grid { grid-template-columns: 1fr; } }

  /* SECTION DIVIDER */
  .section-header { display: flex; align-items: center; gap: 12px; margin: 20px 0 14px; }
  .section-header h2 { font-size: 16px; font-weight: 700; }
  .section-header .line { flex: 1; height: 1px; background: var(--border); }

  /* INSIGHT BOX */
  .insight { background: var(--pill-bg); border: 1px solid rgba(219,0,17,.15); border-radius: 6px; padding: 10px 14px; font-size: 12px; color: var(--text); line-height: 1.6; margin-bottom: 12px; }
  .insight strong { color: var(--hsbc-red); }

  /* LEGEND */
  .legend { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 10px; font-size: 12px; color: var(--muted); }
  .legend-item { display: flex; align-items: center; gap: 5px; }
  .legend-dot { width: 10px; height: 10px; border-radius: 2px; }

  /* FOOTER */
  .footer { text-align: center; padding: 24px; font-size: 11px; color: var(--muted); border-top: 1px solid var(--border); margin-top: 32px; }
</style>
</head>
<body>

<div class="header">
